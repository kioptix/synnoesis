# Example Mosquitto config for the Synnoesis cross-machine transport.
#
# TWO postures shown. The QUICK-TEST block is active; the PRODUCTION block is
# commented. Synnoesis SIGNS every message either way — but signing is not
# encryption, so the broker still sees content (see docs/quickstart.md §6).

# ─────────────────────────────────────────────────────────────────────────────
# QUICK-TEST — one host, loopback only, plaintext, anonymous.
# Safe ONLY because it is bound to localhost and never leaves the machine.
listener 1883 127.0.0.1
allow_anonymous true

persistence true
persistence_location /mosquitto/data/
log_dest stdout

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION (off-box) — require TLS + a password. Uncomment, provide certs and a
# password file, and REMOVE the quick-test block above. Do NOT expose an
# anonymous/plaintext listener on a network interface.
#
# listener 8883 0.0.0.0
# allow_anonymous false
# password_file /mosquitto/config/passwd        # created with `mosquitto_passwd`
# cafile   /mosquitto/certs/ca.crt
# certfile /mosquitto/certs/server.crt
# keyfile  /mosquitto/certs/server.key
# require_certificate false                      # true = also require client certs
#
# On each Synnoesis machine then set:
#   SYN_BROKER=<broker-host>:8883
#   SYN_BROKER_TLS_CA=/path/to/ca.crt
#   SYN_BROKER_USER=<user>
#   SYN_BROKER_PASSFILE=/path/to/pass   # the password, in a 0600 file (never argv)
